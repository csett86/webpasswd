#%PAM-1.0
#
# PAM service used by webpasswd for authenticating the current password and
# applying password-change policy.

auth required pam_unix.so
account required pam_unix.so

# Require password complexity for changes made through webpasswd. The
# enforce_for_root option matters because the webpasswd daemon runs as root.
password requisite pam_pwquality.so minlen=8 enforce_for_root
password required pam_unix.so use_authtok
